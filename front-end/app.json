{
  "expo": {
    "name": "EventUSP",
    "slug": "eventusp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/EventUSP-Dark.png",
    "scheme": "eventusp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "icon": {
        "light": "./assets/images/EventUSP.png",
        "dark": "./assets/images/EventUSP-Dark.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#231F20",
        "foregroundImage": "./assets/images/EventUSP-Foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/EventUSP-Foreground.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "16f95a78-69bd-4cd5-9763-066777a1046e"
      }
    },
    "owner": "losermanos"
  }
}
